#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define BASE1  0
#define BASE2  1
#define KOR1   2
#define KOR2   3
#define ARROWS 4
#define FUNS   5
#define SYM1   6
#define SYM2   7
#define NUMS   8

/ {
   chosen {
      zmk,physical-layout = &five_col_layout;
   };
};

&sl {
    release-after-ms = <500>;
    quick-release;
};

&sk {
    release-after-ms = <500>;
    quick-release;
};

/ {
   macros {
      lang1: lang1 {
         compatible = "zmk,behavior-macro-one-param";
         wait-ms = <0>;
         tap-ms = <0>;
         #binding-cells = <1>;
         bindings =
            <&macro_tap &kp LC(SPACE)>
            , <&macro_param_1to1>
            , <&macro_tap &to MACRO_PLACEHOLDER>;
      };
      lang2: lang2 {
         compatible = "zmk,behavior-macro-one-param";
         wait-ms = <0>;
         tap-ms = <0>;
         #binding-cells = <1>;
         bindings =
            <&macro_param_1to1>
            , <&macro_tap &to MACRO_PLACEHOLDER>;
      };
   };
   combos {
        compatible = "zmk,combos";
        combo_f1 {
            key-positions = <16 25>;
            bindings = <&kp F1>;
            layers = <8>;
        };
        combo_f2 {
            key-positions = <16 26>;
            bindings = <&kp F2>;
            layers = <8>;
        };
        combo_f3 {
            key-positions = <16 27>;
            bindings = <&kp F3>;
            layers = <8>;
        };
        combo_f4 {
            key-positions = <16 13>;
            bindings = <&kp F4>;
            layers = <8>;
        };
        combo_f5 {
            key-positions = <16 14>;
            bindings = <&kp F5>;
            layers = <8>;
        };
        combo_f6 {
            key-positions = <16 15>;
            bindings = <&kp F6>;
            layers = <8>;
        };
        combo_f7 {
            key-positions = <16 1>;
            bindings = <&kp F7>;
            layers = <8>;
        };
        combo_f8 {
            key-positions = <16 2>;
            bindings = <&kp F8>;
            layers = <8>;
        };
        combo_f9 {
            key-positions = <16 3>;
            bindings = <&kp F9>;
            layers = <8>;
        };
        combo_f10 {
            key-positions = <16 24>;
            bindings = <&kp F10>;
            layers = <8>;
        };
        combo_f11 {
            key-positions = <16 12>;
            bindings = <&kp F11>;
            layers = <8>;
        };
        combo_f12 {
            key-positions = <16 0>;
            bindings = <&kp F12>;
            layers = <8>;
        };
        combo_dllr {
            key-positions = <24 25>;
            bindings = <&kp DLLR>;
            layers = <6>;
        };
        combo_caret {
            key-positions = <24 25>;
            bindings = <&kp CARET>;
            layers = <7>;
        };
        combo_bslh {
            key-positions = <0 1>;
            bindings = <&kp BSLH>;
            layers = <6>;
        };
        combo_grave {
            key-positions = <0 1>;
            bindings = <&kp GRAVE>;
            layers = <7>;
        };
        combo_lshft {
            key-positions = <13 14>;
            bindings = <&sk LSHFT>;
            layers = <0 1 2 3 6 7>;
        };
        combo_cw {
            key-positions = <1 2>;
            bindings = <&caps_word>;
            layers = <0 1 2 3 6 7>;
        };
        combo_tab {
            key-positions = <25 26>;
            bindings = <&kp TAB>;
            layers = <0 1 2 3 6 7>;
        };
        combo_esc {
            key-positions = <14 15>;
            bindings = <&kp ESC>;
            layers = <0 1 2 3 6 7>;
        };
        combo_ret {
            key-positions = <26 27>;
            bindings = <&kp RET>;
            layers = <0 1 2 3 6 7>;
        };
        combo_lcmd {
            key-positions = <15 16>;
            bindings = <&sk LCMD>;
            layers = <0 1 2 3 6 7>;
        };
        combo_lctrl {
            key-positions = <27 28>;
            bindings = <&sk LCTRL>;
            layers = <0 1 2 3 6 7>;
        };
        combo_lalt {
            key-positions = <3 4>;
            bindings = <&sk LALT>;
            layers = <0 1 2 3 6 7>;
        };
    };
   keymap {
      compatible = "zmk,keymap";
      base1_layer {
         display-name = "BASE1";
         bindings = <
            &kp F     &kp D &kp I &kp S &kp J &none &none &none &none &none &none &none
            &kp SPACE &kp T &kp E &kp N &kp Q &none &none &none &none &none &none &none
            &kp U     &kp C &kp O &kp R &kp Z               &none &none &none &none &none
            &sl ARROWS &sl BASE2 &sl SYM1 &none &none &none
            >;
      };
      base2_layer {
         display-name = "BASE2";
         bindings = <
            &kp V &kp G &kp Y &kp X &none       &none &none &none &none &none &none &none
            &kp P &kp M &kp A &kp L &lang1 KOR1 &none &none &none &none &none &none &none
            &kp W &kp B &kp K &kp H &lang2 KOR1             &none &none &none &none &none
            &trans &to BASE1 &trans &none &none &none
            >;
      };
      kor1_layer {
         display-name = "KOR1";
         bindings = <
            &kp C     &kp E &kp I &kp Q &kp Z &none &none &none &none &none &none &none
            &kp SPACE &kp S &kp R &kp D &kp V &none &none &none &none &none &none &none
            &kp G     &kp A &kp W &kp F &kp X               &none &none &none &none &none
            &sl ARROWS &sl KOR2 &sl SYM1 &none &none &none
            >;
      };
      kor2_layer {
         display-name = "KOR2";
         bindings = <
            &kp B &kp P &kp N &kp I &none        &none &none &none &none &none &none &none
            &kp J &kp M &kp L &kp K &lang1 BASE1 &none &none &none &none &none &none &none
            &kp Y &kp O &kp H &kp U &lang2 BASE1             &none &none &none &none &none
            &trans &to KOR1 &trans &none &none &none
            >;
      };
      arrows_layer {
         display-name = "ARROWS";
         bindings = <
            &kp HOME &kp PG_DN &kp PG_UP &kp END   &none &none &none &none &none &none &none &none
            &kp LEFT &kp DOWN  &kp UP    &kp RIGHT &none &none &none &none &none &none &none &none
            &sl FUNS &kp DEL   &kp LC(B) &kp CAPS  &kp INS           &none &none &none &none &none
            &none &none &none &none &none &none
            >;
      };
      funs_layer {
         display-name = "FUNS";
         bindings = <
            &bt BT_SEL 3 &bt BT_SEL 2 &bt BT_SEL 1 &bt BT_SEL 0 &bt BT_CLR &none &none &none &none &none &none &none
            &kp C_PREV   &kp C_VOL_DN &kp C_VOL_UP &kp C_NEXT   &none      &none &none &none &none &none &none &none
            &none        &kp C_BRI_DN &kp C_BRI_UP &kp C_PP     &none                  &none &none &none &none &none
            &none &none &none &none &none &none
            >;
      };
      sym1_layer {
         display-name = "SYM1";
         bindings = <
            &kp STAR &kp FLSH &kp MINUS &kp PLUS  &kp HASH &none &none &none &none &none &none &none
            &sl SYM2 &kp EQL  &kp UNDER &kp COMMA &kp AMPS &none &none &none &none &none &none &none
            &kp LBRC &kp LBKT &kp LPAR  &kp LT    &kp AT               &none &none &none &none &none
            &none &none &sl NUMS &none &none &none
            >;
      };
      sym2_layer {
         display-name = "SYM2";
         bindings = <
            &kp SQT  &kp DQT  &kp QMARK &kp EXCL &kp PRCNT &none &none &none &none &none &none &none
            &to SYM1 &kp DOT  &kp COLON &kp SEMI &kp PIPE  &none &none &none &none &none &none &none
            &kp RBRC &kp RBKT &kp RPAR  &kp GT   &kp AT                &none &none &none &none &none
            &none &none &none &none &none &none
            >;
      };
      nums_layer {
         display-name = "NUMS";
         bindings = <
            &kp MINUS &kp N7 &kp N8 &kp N9 &kp FSLH &none &none &none &none &none &none &none
            &kp PLUS  &kp N4 &kp N5 &kp N6 &kp STAR &none &none &none &none &none &none &none
            &kp N0    &kp N1 &kp N2 &kp N3 &kp DOT               &none &none &none &none &none
            &kp DOT &none &none &none &none &none
            >;
      };
   };
};
